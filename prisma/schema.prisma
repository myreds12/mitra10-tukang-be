// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("MSSQL_URL")
}

model bank {
  id         Int       @id @default(autoincrement())
  bank_name  String    @db.VarChar(50)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?
  sales      sales[]
  vendor     vendor[]
  manager    manager[]
}

model area {
  id          Int           @id @default(autoincrement())
  area        String        @db.VarChar(50)
  created_at  DateTime      @default(now()) @db.DateTime()
  updated_at  DateTime?     @db.DateTime()
  deleted_at  DateTime?     @db.DateTime()
  members     members[]
  store       store[]
  vendor_area vendor_area[]
  tukang_area tukang_area[]
}

model city {
  id          Int    @id @default(autoincrement())
  province_id Int?
  city_name   String @db.VarChar(255)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  province province? @relation(fields: [province_id], references: [id])
}

model data_master {
  id    Int    @id @default(autoincrement())
  value Int?
  name  String @db.VarChar(255)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?
}

model employee {
  id Int @id @default(autoincrement())

  position_id Int?
  store_id    Int?
  user_id     Int? @unique

  full_name        String    @db.VarChar(255)
  email            String    @db.VarChar(255)
  birth            DateTime? @db.DateTime()
  nik              String?   @db.VarChar(50)
  phone_number     String?   @db.VarChar(50)
  whatsapp_number  String?   @db.VarChar(50)
  default_password String?   @db.VarChar(50)

  created_at DateTime?  @default(now()) @db.DateTime()
  updated_at DateTime?  @db.DateTime()
  deleted_at DateTime?  @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?
  positions  positions? @relation(fields: [position_id], references: [id])
  store      store?     @relation(fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users?     @relation(fields: [user_id], references: [id])
}

model items {
  id Int @id @default(autoincrement())

  type            Int?    @default(0) // 1 = GRATIS, 2 = PEMASANGAN_TANPA_SURVEY
  invoice_nominal Decimal @default(0) @db.Decimal(32, 2)
  invoices_prices Decimal @default(0) @db.Decimal(32, 2)
  item_name       String? @db.VarChar(255)
  item_code       String? @db.VarChar(255)
  service_name    String  @db.VarChar(255)
  default_price   Decimal @default(0) @db.Decimal(32, 2)
  category_id     Int

  is_active Boolean @default(true)

  created_at DateTime? @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  m_order_details   m_order_details[]
  prices            prices[]
  work_order_items  work_order_items[]
  category          categories          @relation(fields: [category_id], references: [id])
  quotation_details quotation_details[]
}

//FIXME: CHECK THIS MODEL
model promotion {
  id             Int     @id @default(autoincrement())
  name           String? @db.VarChar(255)
  min_order      Decimal @default(0) @db.Decimal(32, 2)
  max_order      Decimal @default(0) @db.Decimal(32, 2)
  promotion      Decimal @default(0) @db.Decimal(32, 2)
  promotion_type Int?    @default(1) // 1 = Percentage, 2 = Nominal

  periodic_start DateTime?
  periodic_end   DateTime?

  created_at DateTime? @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  quotation        quotation[]
  promotion_stores promotion_stores[]
}

model promotion_stores {
  id Int @id @default(autoincrement())

  promotion_id Int
  store_id     Int

  created_by Int?
  updated_by Int?
  deleted_by Int?

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  store     store     @relation(fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  promotion promotion @relation(fields: [promotion_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model logs {
  id          Int       @id @default(autoincrement())
  module_type String?   @db.VarChar(255)
  module_id   Int?
  issuer_type String?   @db.VarChar(255)
  issuer_id   Int?
  properties  String?   @db.Text
  created_at  DateTime? @default(now()) @db.DateTime()
}

model members {
  id            Int     @id @default(autoincrement())
  area_id       Int?
  join_location Int?
  member_number String? @db.VarChar(20)

  full_name       String   @db.VarChar(255)
  email           String?  @db.VarChar(255)
  phone_number    String?  @db.VarChar(20)
  whatsapp_number String?  @db.VarChar(20)
  address_1       String   @db.VarChar(255)
  address_2       String?  @db.VarChar(255)
  zip_code        String?  @db.VarChar(10)
  rating          Int?     @default(0)
  join_date       DateTime @default(now()) @db.DateTime()

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?

  order               orders[]
  join_location_store store?   @relation(fields: [join_location], references: [id], onDelete: NoAction, onUpdate: NoAction)
  area                area?    @relation(fields: [area_id], references: [id])
}

model menus {
  id        Int    @id @default(autoincrement())
  parent_id Int?
  parent    menus? @relation("ChildMenus", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  title     String  @db.VarChar(50)
  url       String  @db.VarChar(255)
  icon      String  @db.VarChar(50)
  is_active Boolean @default(true)

  created_at DateTime? @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?

  childMenus menus[] @relation("ChildMenus") // Define the reverse relation for self-referencing

  permissions permissions[]
}

model notifications {
  id        Int  @id @default(autoincrement())
  user_id   Int
  module_id Int?
  status    Int?

  data        String? @db.Text()
  module_type String? @db.VarChar(100)
  action      String? @db.Text()
  is_read     Boolean @default(false)

  created_at DateTime @default(now()) @db.DateTime()

  created_by Int?

  user users @relation(fields: [user_id], references: [id])
}

model positions {
  id            Int        @id @default(autoincrement())
  position_name String     @db.VarChar(50)
  is_active     Boolean    @default(true)
  created_at    DateTime?  @default(now()) @db.DateTime()
  updated_at    DateTime?  @db.DateTime()
  deleted_at    DateTime?  @db.DateTime()
  created_by    Int?
  updated_by    Int?
  deleted_by    Int?
  employee      employee[]
}

model province {
  id            Int       @id @default(autoincrement())
  province_name String
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.DateTime()
  updated_at    DateTime? @db.DateTime()
  deleted_at    DateTime? @db.DateTime()
  created_by    Int?
  updated_by    Int?
  deleted_by    Int?
  city          city[]
}

model roles {
  id               Int                @id @default(autoincrement())
  name             String             @db.VarChar(255)
  is_active        Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.DateTime()
  updated_at       DateTime?          @db.DateTime()
  deleted_at       DateTime?          @db.DateTime()
  created_by       Int?
  updated_by       Int?
  deleted_by       Int?
  role_permissions role_permissions[]
  users            users[]
}

model permissions {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(255)
  is_active Boolean @default(true)
  menu_id   Int

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  menus            menus              @relation(fields: [menu_id], references: [id])
  role_permissions role_permissions[]
}

model role_permissions {
  id Int @id @default(autoincrement())

  role_id       Int
  permission_id Int

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  roles       roles       @relation(fields: [role_id], references: [id])
  permissions permissions @relation(fields: [permission_id], references: [id])
}

model users {
  id      Int @id @default(autoincrement())
  role_id Int

  username        String    @db.VarChar(255)
  password        String    @db.VarChar(255)
  forget_password DateTime? @db.DateTime()
  profile_picture String?   @default("") @db.VarChar(255)

  is_active Boolean @default(true)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  roles         roles           @relation(fields: [role_id], references: [id])
  store         store[]
  sales         sales[]
  manager       manager[]
  employee      employee?
  tukang        tukang[]
  pic_vendor    pic_vendor[]
  notifications notifications[]
}

model sales {
  id       Int  @id @default(autoincrement())
  store_id Int?
  user_id  Int?

  full_name      String  @db.VarChar(255)
  nik            String? @default("") @db.VarChar(20)
  bank_id        Int?
  bank_branch    String? @db.VarChar(50)
  account_name   String? @db.VarChar(255)
  account_number String? @db.VarChar(255)
  phone_number   String? @db.VarChar(50)
  sales_brand    String? @default("")
  order_total    Int?    @default(0)

  is_active Boolean @default(true)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  store            store?             @relation(fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users?             @relation(fields: [user_id], references: [id])
  bank             bank?              @relation(fields: [bank_id], references: [id])
  orders           orders[]
  sales_brands     sales_brands[]
  sales_categories sales_categories[]
  m_order_details  m_order_details[]
  sales_incentive  sales_incentive[]
}

model brands {
  id Int @id @default(autoincrement())

  name String @db.VarChar(255)

  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?

  sales_brands sales_brands[]
}

model sales_brands {
  id        Int @id @default(autoincrement())
  sales_id  Int
  brands_id Int

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?

  sales  sales  @relation(fields: [sales_id], references: [id])
  brands brands @relation(fields: [brands_id], references: [id])
}

model sales_categories {
  id          Int  @id @default(autoincrement())
  sales_id    Int?
  category_id Int?

  commission Decimal? @default("0") @db.Decimal(32, 2)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?

  sales      sales?      @relation(fields: [sales_id], references: [id])
  categories categories? @relation(fields: [category_id], references: [id])
}

model service_type {
  id             Int              @id @default(autoincrement())
  service_type   String           @db.VarChar(45)
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now()) @db.DateTime()
  updated_at     DateTime?        @db.DateTime()
  deleted_at     DateTime?        @db.DateTime()
  created_by     Int?
  updated_by     Int?
  deleted_by     Int?
  vendor_service vendor_service[]
  tukang_service tukang_service[]
}

model store {
  id             Int  @id @default(autoincrement())
  area_id        Int? @default(0)
  user_id        Int?
  store_group_id Int?

  email              String  @default("")
  store_name         String  @db.VarChar(45)
  address            String  @db.VarChar(255)
  additional_address String? @db.VarChar(255)
  zip_code           String? @default("") @db.VarChar(45)
  phone_number_1     String? @default("")
  phone_number_2     String? @default("")
  bank_name          String? @default("")
  bank_account       String? @default("")
  bank_number        String? @default("")

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  sales     sales[]
  manager   manager[]
  employee  employee[]
  orders    orders[]
  quotation quotation[]
  members   members[]

  area             area?              @relation(fields: [area_id], references: [id])
  store_group      store_group?       @relation(fields: [store_group_id], references: [id])
  price_stores     price_stores[]
  vendor_store     vendor_store[]
  users            users?             @relation(fields: [user_id], references: [id])
  promotion_stores promotion_stores[]
  incentive_store  incentive_store[]
  store_incentive  store_incentive[]
}

model store_group {
  id Int @id @default(autoincrement())

  group_name String @db.VarChar(255)

  // store_id Int
  // group_id Int

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?
  store      store[]
}

model tukang {
  id        Int  @id @default(autoincrement())
  vendor_id Int?
  user_id   Int?

  full_name    String    @db.VarChar(45)
  address      String    @db.VarChar(255)
  phone_number String    @db.VarChar(45)
  ktp_number   String?   @default("") @db.VarChar(45)
  email        String    @db.VarChar(45)
  bod          DateTime  @db.DateTime()
  join_date    DateTime? @default(now()) @db.DateTime()
  is_active    Boolean   @default(true)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?

  vendor            vendor?             @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users?              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tukang_service    tukang_service[]
  tukang_document   tukang_document[]
  work_order_tukang work_order_tukang[]
  work_order_items  work_order_items[]
  tukang_area       tukang_area[]
  request_tukang    request_tukang[]    @relation("request_tukang")
  replace_tukang    request_tukang[]    @relation("replace_tukang")
  reschedule_tukang reschedule_tukang[]
}

model tukang_area {
  id Int @id @default(autoincrement())

  tukang_id Int
  area_id   Int

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?

  area   area   @relation(fields: [area_id], references: [id])
  tukang tukang @relation(fields: [tukang_id], references: [id])
}

model tukang_document {
  id        Int @id @default(autoincrement())
  tukang_id Int

  document_name String @db.VarChar(255)
  path          String @db.VarChar(255)

  is_active Boolean @default(true)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  tukang tukang @relation(fields: [tukang_id], references: [id])
}

model tukang_service {
  id              Int  @id @default(autoincrement())
  tukang_id       Int?
  service_type_id Int?

  is_active Boolean @default(true)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by   Int?
  updated_by   Int?
  deleted_by   Int?
  tukang       tukang?       @relation(fields: [tukang_id], references: [id])
  service_type service_type? @relation(fields: [service_type_id], references: [id])
}

model vendor {
  id      Int  @id @default(autoincrement())
  bank_id Int?

  type           Int?      @default(1) // 1 = NON PKP, 2 = PKP
  pkp_nominal    Decimal   @default(0) @db.Decimal(32, 2)
  pic_name       String    @default("") @db.VarChar(200)
  company_name   String    @db.VarChar(45)
  address        String    @db.VarChar(200)
  phone_number   String    @db.VarChar(30)
  ktp_number     String?
  npwp_number    String?
  email_address  String    @db.VarChar(100)
  join_date      DateTime? @default(now()) @db.DateTime()
  is_active      Boolean   @default(true)
  account_name   String?   @default("")
  account_number String?   @default("")
  margin_type    Int       @default(1)
  margin_nominal Decimal   @default(0) @db.Decimal(32, 2)
  nominal_survey Decimal   @default(0) @db.Decimal(32, 2)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  max_order  Int       @default(3) @db.SmallInt()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  tukang          tukang[]
  vendor_area     vendor_area[]
  vendor_document vendor_document[]
  vendor_service  vendor_service[]
  orders          orders[]
  work_orders     work_orders[]
  invoices        invoices[]
  vendor_store    vendor_store[]
  pic_vendor      pic_vendor[]

  bank bank? @relation(fields: [bank_id], references: [id])
}

model pic_vendor {
  id            Int       @id @default(autoincrement())
  vendor_id     Int
  user_id       Int
  pic_name      String    @default("") @db.VarChar(200)
  email_address String    @default("") @db.VarChar(100)
  created_at    DateTime  @default(now()) @db.DateTime()
  updated_at    DateTime? @db.DateTime()
  deleted_at    DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  users  users  @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendor vendor @relation(fields: [vendor_id], references: [id])
}

model vendor_store {
  id Int @id @default(autoincrement())

  store_id  Int @map("storeId")
  vendor_id Int @map("vendorId")

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?
  store      store  @relation(fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendor     vendor @relation(fields: [vendor_id], references: [id])
}

model vendor_area {
  id Int @id @default(autoincrement())

  vendor_id Int?
  area_id   Int?

  default_discount Decimal @default(0) @db.Decimal(32, 2)
  default_markup   String? @db.VarChar(45)
  default_unit     String  @default("unit") @db.VarChar(45)
  is_active        Boolean @default(true)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  vendor vendor? @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  area   area?   @relation(fields: [area_id], references: [id])
}

model vendor_document {
  id            Int       @id @default(autoincrement())
  vendor_id     Int?
  document_name String    @db.VarChar(255)
  path          String    @db.VarChar(255)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.DateTime()
  updated_at    DateTime? @db.DateTime()
  deleted_at    DateTime? @db.DateTime()
  created_by    Int?
  updated_by    Int?
  deleted_by    Int?
  vendor        vendor?   @relation(fields: [vendor_id], references: [id])
}

model vendor_service {
  id              Int           @id @default(autoincrement())
  vendor_id       Int?
  service_type_id Int?
  is_active       Boolean       @default(true)
  created_at      DateTime      @default(now()) @db.DateTime()
  updated_at      DateTime?     @db.DateTime()
  deleted_at      DateTime?     @db.DateTime()
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  vendor          vendor?       @relation(fields: [vendor_id], references: [id])
  service_type    service_type? @relation(fields: [service_type_id], references: [id])
}

model status {
  id Int @id @default(autoincrement())

  category       String
  description    String
  status_urgency Int?   @default(0)

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime?

  order               orders[]
  complaints          complaints[]
  work_orders         work_orders[]
  quotation           quotation[]
  remedials           remedials[]
  refund              refund[]
  work_order_status   work_order_status[]
  order_history       order_histories[]
  compliant_histories complaint_histories[]
  reschedule          reschedule[]
  reschedule_status   reschedule_status[]
  email_messages      email_messages[]
}

model orders {
  id                Int  @id @default(autoincrement())
  member_id         Int
  store_id          Int
  project_status_id Int
  vendor_id         Int?
  sales_id          Int?

  project_address       String
  project_number        String    @default("0")
  notes                 String?   @db.VarChar(2555)
  receipt_number        String?   @db.NVarChar(30)
  request_survey        DateTime? @db.DateTime()
  request_work          DateTime? @db.DateTime()
  payment_type          String    @db.VarChar(200)
  grand_total           Decimal?  @db.Decimal(32, 2)
  grand_total_comission Decimal?  @db.Decimal(32, 2)
  print_counter         Int       @default(0) @db.TinyInt()
  is_overdistance       Int       @default(0)
  additional_fee        Decimal?  @default(0) @db.Decimal(32, 2)

  created_by Int?
  updated_by Int?
  deleted_by Int?

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  members members? @relation(fields: [member_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
