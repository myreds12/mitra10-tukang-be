// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("MSSQL_URL")
}

model bank {
  id          Int           @id @default(autoincrement())
  bank_name   String        @db.VarChar(50)
  is_active   Boolean       @default(true)
  created_at  DateTime      @default(now()) @db.DateTime()
  updated_at  DateTime?     @db.DateTime()
  deleted_at  DateTime?     @db.DateTime()
  created_by  Int?
  updated_by  Int?
  deleted_by  Int?
  sales       sales[]
  vendor_bank vendor_bank[]
}

model city {
  id          Int       @id @default(autoincrement())
  province_id Int?
  city_name   String    @db.VarChar(255)
  created_at  DateTime  @default(now()) @db.DateTime()
  updated_at  DateTime? @db.DateTime()
  deleted_at  DateTime? @db.DateTime()
  created_by  Int?
  updated_by  Int?
  deleted_by  Int?
  members     members[]
  vendor      vendor[]
  province    province? @relation(fields: [province_id], references: [id])
}

model employee {
  id              Int        @id @default(autoincrement())
  position_id     Int?
  store_id        Int?
  user_id         Int?
  first_name      String     @db.VarChar(50)
  middle_name     String?    @db.VarChar(50)
  last_name       String     @db.VarChar(50)
  full_name       String     @db.VarChar(255)
  email           String     @db.VarChar(255)
  birth           DateTime   @db.DateTime()
  gender          String     @db.VarChar(50)
  nik             String     @db.VarChar(50)
  phone_number    String     @db.VarChar(50)
  whatsapp_number String     @db.VarChar(50)
  created_at      DateTime?  @default(now()) @db.DateTime()
  updated_at      DateTime?  @db.DateTime()
  deleted_at      DateTime?  @db.DateTime()
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  positions       positions? @relation(fields: [position_id], references: [id])
  store           store?     @relation(fields: [store_id], references: [id])
  users           users?     @relation(fields: [user_id], references: [id])
}

model items {
  id              Int               @id @default(autoincrement())
  store_id        Int?
  unit_id         Int
  item_name       String            @db.VarChar(45)
  created_at      DateTime?         @default(now()) @db.DateTime()
  updated_at      DateTime?         @db.DateTime()
  deleted_at      DateTime?         @db.DateTime()
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  store           store?            @relation(fields: [store_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  units           units             @relation(fields: [unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  m_order_details m_order_details[]
  prices          prices[]
}

model logs {
  id          Int       @id @default(autoincrement())
  module_type String?   @db.VarChar(255)
  module_id   Int?
  issuer_type String?   @db.VarChar(255)
  issuer_id   Int?
  properties  String?   @db.Text
  created_at  DateTime? @default(now()) @db.DateTime()
}

model members {
  id              Int       @id @default(autoincrement())
  full_name       String    @db.VarChar(255)
  email           String    @unique() @db.VarChar(255)
  phone_number    String    @db.VarChar(20)
  whatsapp_number String    @db.VarChar(20)
  address_1       String    @db.VarChar(255)
  address_2       String?   @db.VarChar(255)
  city_id         Int?
  zip_code        String?   @db.VarChar(10)
  rating          Int?
  join_date       DateTime  @default(now()) @db.DateTime()
  join_location   Int
  created_at      DateTime  @default(now()) @db.DateTime()
  updated_at      DateTime? @db.DateTime()
  deleted_at      DateTime? @db.DateTime()
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  city            city?     @relation(fields: [city_id], references: [id])
  order           orders[]
}

model menus {
  id                    Int                     @id @default(autoincrement())
  title                 String                  @db.VarChar(50)
  url                   String                  @db.VarChar(255)
  icon                  String                  @db.VarChar(50)
  parent_id             Int
  is_active             Boolean                 @default(true)
  created_at            DateTime?               @default(now()) @db.DateTime()
  updated_at            DateTime?               @db.DateTime()
  deleted_at            DateTime?               @db.DateTime()
  created_by            Int?
  updated_by            Int?
  deleted_by            Int?
  role_menus            role_menus[]
  user_menu_permissions user_menu_permissions[]
}

model permissions {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @db.VarChar(255)
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.DateTime()
  updated_at            DateTime?               @db.DateTime()
  deleted_at            DateTime?               @db.DateTime()
  role_menu_permissions role_menu_permissions[]
  user_menu_permissions user_menu_permissions[]
}

model positions {
  id            Int        @id @default(autoincrement())
  position_name String     @db.VarChar(50)
  is_active     Boolean    @default(true)
  created_at    DateTime?  @default(now()) @db.DateTime()
  updated_at    DateTime?  @db.DateTime()
  deleted_at    DateTime?  @db.DateTime()
  created_by    Int?
  updated_by    Int?
  deleted_by    Int?
  employee      employee[]
}

model province {
  id            Int       @id @default(autoincrement())
  province_name String
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.DateTime()
  updated_at    DateTime? @db.DateTime()
  deleted_at    DateTime? @db.DateTime()
  created_by    Int?
  updated_by    Int?
  deleted_by    Int?
  city          city[]
}

model roles {
  id         Int          @id @default(autoincrement())
  name       String       @db.VarChar(255)
  is_active  Boolean      @default(true)
  created_at DateTime     @default(now()) @db.DateTime()
  updated_at DateTime?    @db.DateTime()
  deleted_at DateTime?    @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?
  user_roles user_roles[]
  role_menus role_menus[]
}

model role_menus {
  id                    Int                     @id @default(autoincrement())
  role_id               Int?
  menu_id               Int?
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.DateTime()
  updated_at            DateTime?               @db.DateTime()
  deleted_at            DateTime?               @db.DateTime()
  created_by            Int?
  updated_by            Int?
  deleted_by            Int?
  roles                 roles?                  @relation(fields: [role_id], references: [id])
  menus                 menus?                  @relation(fields: [menu_id], references: [id])
  role_menu_permissions role_menu_permissions[]
}

model role_menu_permissions {
  id            Int          @id @default(autoincrement())
  role_menu_id  Int?
  permission_id Int?
  created_at    DateTime     @default(now()) @db.DateTime()
  updated_at    DateTime?    @db.DateTime()
  role_menus    role_menus?  @relation(fields: [role_menu_id], references: [id])
  permissions   permissions? @relation(fields: [permission_id], references: [id])
}

model sales {
  id           Int       @id @default(autoincrement())
  store_id     Int?
  user_id      Int?
  full_name    String    @db.VarChar(255)
  nik          String    @db.VarChar(20)
  bank_id      Int?
  bank_branch  String    @db.VarChar(50)
  account_name String    @db.VarChar(255)
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.DateTime()
  updated_at   DateTime? @db.DateTime()
  deleted_at   DateTime? @db.DateTime()
  created_by   Int?
  updated_by   Int?
  deleted_by   Int?
  store        store?    @relation(fields: [store_id], references: [id])
  users        users?    @relation(fields: [user_id], references: [id])
  bank         bank?     @relation(fields: [bank_id], references: [id])
}

model service_type {
  id             Int              @id @default(autoincrement())
  service_type   String           @db.VarChar(45)
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now()) @db.DateTime()
  updated_at     DateTime?        @db.DateTime()
  deleted_at     DateTime?        @db.DateTime()
  created_by     Int?
  updated_by     Int?
  deleted_by     Int?
  vendor_service vendor_service[]
  tukang_service tukang_service[]
}

model store {
  id          Int           @id @default(autoincrement())
  store_name  String        @db.VarChar(45)
  address     String        @db.VarChar(45)
  city_id     Int
  zip_code    String        @db.VarChar(45)
  created_at  DateTime      @default(now()) @db.DateTime()
  updated_at  DateTime?     @db.DateTime()
  deleted_at  DateTime?     @db.DateTime()
  created_by  Int?
  updated_by  Int?
  deleted_by  Int?
  sales       sales[]
  items       items[]
  vendor_area vendor_area[]
  employee    employee[]
  orders      orders[]
}

model tukang {
  id             Int              @id @default(autoincrement())
  vendor_id      Int?
  user_id        Int?
  full_name      String           @db.VarChar(45)
  ktp_number     String           @db.VarChar(45)
  ktp_path       String           @db.VarChar(45)
  email          String           @db.VarChar(45)
  join_date      DateTime?        @db.DateTime()
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now()) @db.DateTime()
  updated_at     DateTime?        @db.DateTime()
  deleted_at     DateTime?        @db.DateTime()
  created_by     Int?
  updated_by     Int?
  deleted_by     Int?
  vendor         vendor?          @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users          users?           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tukang_service tukang_service[]
  orders         orders[]
}

model tukang_service {
  id              Int           @id @default(autoincrement())
  tukang_id       Int?
  service_type_id Int?
  is_active       Boolean       @default(true)
  created_at      DateTime      @default(now()) @db.DateTime()
  updated_at      DateTime?     @db.DateTime()
  deleted_at      DateTime?     @db.DateTime()
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  tukang          tukang?       @relation(fields: [tukang_id], references: [id])
  service_type    service_type? @relation(fields: [service_type_id], references: [id])
}

model users {
  id                    Int                     @id @default(autoincrement())
  username              String                  @db.VarChar(255)
  password              String                  @db.VarChar(255)
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.DateTime()
  updated_at            DateTime?               @db.DateTime()
  deleted_at            DateTime?               @db.DateTime()
  created_by            Int?
  updated_by            Int?
  deleted_by            Int?
  sales                 sales[]
  user_roles            user_roles[]
  user_menu_permissions user_menu_permissions[]
  employee              employee[]
  vendor                vendor[]
  tukang                tukang[]
  orders                orders[]
}

model user_menu_permissions {
  id            Int          @id @default(autoincrement())
  user_id       Int?
  menu_id       Int?
  created_at    DateTime     @default(now()) @db.DateTime()
  updated_at    DateTime?    @db.DateTime()
  users         users?       @relation(fields: [user_id], references: [id])
  menus         menus?       @relation(fields: [menu_id], references: [id])
  permissions   permissions? @relation(fields: [permission_id], references: [id])
  permission_id Int?
}

model user_roles {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  role_id    Int?
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  created_by Int?
  updated_by Int?
  deleted_by Int?
  users      users?    @relation(fields: [user_id], references: [id])
  roles      roles?    @relation(fields: [role_id], references: [id])
}

model vendor {
  id              Int               @id @default(autoincrement())
  user_id         Int?
  company_name    String            @db.VarChar(45)
  address         String            @db.VarChar(200)
  phone_number    String            @db.VarChar(30)
  email_address   String            @db.VarChar(100)
  join_date       DateTime?         @default(now()) @db.DateTime()
  city_id         Int?
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.DateTime()
  updated_at      DateTime?         @db.DateTime()
  deleted_at      DateTime?         @db.DateTime()
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  tukang          tukang[]
  vendor_area     vendor_area[]
  users           users?            @relation(fields: [user_id], references: [id])
  city            city?             @relation(fields: [city_id], references: [id])
  vendor_bank     vendor_bank[]
  vendor_document vendor_document[]
  vendor_service  vendor_service[]
  orders          orders[]
}

model vendor_area {
  id               Int       @id @default(autoincrement())
  vendor_id        Int?
  area_serve       Int?
  default_discount Decimal   @db.Decimal(2, 0)
  default_markup   String    @db.VarChar(45)
  default_unit     String    @db.VarChar(45)
  is_active        Boolean   @default(true)
  created_at       DateTime  @default(now()) @db.DateTime()
  updated_at       DateTime? @db.DateTime()
  deleted_at       DateTime? @db.DateTime()
  created_by       Int?
  updated_by       Int?
  deleted_by       Int?
  vendor           vendor?   @relation(fields: [vendor_id], references: [id])
  store            store?    @relation(fields: [area_serve], references: [id])
}

model vendor_bank {
  id           Int       @id @default(autoincrement())
  vendor_id    Int?
  bank_id      Int?
  account_name String    @db.VarChar(255)
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now()) @db.DateTime()
  updated_at   DateTime? @db.DateTime()
  deleted_at   DateTime? @db.DateTime()
  created_by   Int?
  updated_by   Int?
  deleted_by   Int?
  vendor       vendor?   @relation(fields: [vendor_id], references: [id])
  bank         bank?     @relation(fields: [bank_id], references: [id])
}

model vendor_document {
  id            Int       @id @default(autoincrement())
  vendor_id     Int?
  document_name String    @db.VarChar(255)
  path          String    @db.VarChar(255)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now()) @db.DateTime()
  updated_at    DateTime? @db.DateTime()
  deleted_at    DateTime? @db.DateTime()
  created_by    Int?
  updated_by    Int?
  deleted_by    Int?
  vendor        vendor?   @relation(fields: [vendor_id], references: [id])
}

model vendor_service {
  id              Int           @id @default(autoincrement())
  vendor_id       Int?
  service_type_id Int?
  is_active       Boolean       @default(true)
  created_at      DateTime      @default(now()) @db.DateTime()
  updated_at      DateTime?     @db.DateTime()
  deleted_at      DateTime?     @db.DateTime()
  created_by      Int?
  updated_by      Int?
  deleted_by      Int?
  vendor          vendor?       @relation(fields: [vendor_id], references: [id])
  service_type    service_type? @relation(fields: [service_type_id], references: [id])
}

model status {
  id              Int               @id @default(autoincrement())
  category        String
  description     String
  created_at      DateTime          @default(now()) @db.DateTime()
  updated_at      DateTime?
  order           orders[]
  m_order_details m_order_details[]
}

model orders {
  id                Int  @id @default(autoincrement())
  member_id         Int?
  seles_id          Int?
  vendor_id         Int?
  tukang_id         Int?
  project_status_id Int
  category_id       Int
  store_id          Int

  project_address         String
  receipt_number          String  @db.NVarChar(30)
  receipt_path            String? @db.Text
  total_estimate_workdays Int     @db.TinyInt
  payment_type            String  @db.VarChar(200)
  grand_total             Decimal @db.Decimal(32, 2)
  grand_total_comission   Decimal @db.Decimal(32, 2)
  print_counter           Int     @db.TinyInt()

  created_by Int?
  updated_by Int?
  deleted_by Int?

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  members         members?          @relation(fields: [member_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seles           users?            @relation(fields: [seles_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendor          vendor?           @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tukang          tukang?           @relation(fields: [tukang_id], references: [id])
  status          status            @relation(fields: [project_status_id], references: [id])
  categories      categories        @relation(fields: [category_id], references: [id])
  store           store             @relation(fields: [store_id], references: [id])
  m_order_details m_order_details[]
}

model m_order_details {
  id              Int @id @default(autoincrement())
  order_id        Int
  item_id         Int
  order_status_id Int

  unit         String  @db.VarChar(200)
  unit_price   Decimal @db.Decimal(2, 0)
  quote_price  Decimal @db.Decimal(2, 0)
  quantity     Decimal @db.Decimal(2, 0)
  total        Int
  survey_price Decimal @db.Decimal(2, 0)
  comission    Int

  created_by Int?
  updated_by Int?
  deleted_by Int?

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  order  orders @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  item   items  @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status status @relation(fields: [order_status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model prices {
  id               Int      @id @default(autoincrement())
  item_id          Int
  unit_id          Int
  periodic_start   DateTime
  periodic_end     DateTime
  nominal_discount String   @db.VarChar(50)
  price            Int
  is_active        Boolean  @default(true)

  created_by Int?
  updated_by Int?
  deleted_by Int?

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()

  units units @relation(fields: [unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items items @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model units {
  id        Int     @id @default(autoincrement())
  unit_name String  @db.VarChar(200)
  is_active Boolean @default(true)

  created_by Int?
  updated_by Int?
  deleted_by Int?

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  prices     prices[]
  items      items[]
}

model categories {
  id            Int    @id @default(autoincrement())
  category_name String @db.VarChar(200)

  created_by Int?
  updated_by Int?
  deleted_by Int?

  created_at DateTime  @default(now()) @db.DateTime()
  updated_at DateTime? @db.DateTime()
  deleted_at DateTime? @db.DateTime()
  orders     orders[]
}
