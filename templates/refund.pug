doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport', content='width=device-width, initial-scale=1.0')
  title Order Confirmation
  link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap', rel='stylesheet')
.container(style='\
max-width: 768px;\
margin: 0 auto;\
background-color: #ffffff;\
box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\
border-radius: 0.5rem;\
overflow: hidden;\
')
  .header
    img(src=`${data.message && data.message.email_message_image && data.message.email_message_image.length > 0 ? `${data.apiUrl}/public/mails-image/${data.message.email_message_image.filter((x) => x.type === 1)[0].path}` : 'https://i.ibb.co/LhrxWt7/header-email-instalasi-01.jpg'}`, alt="Banner Image", style="width: 100%; height: auto;")
  .order-details(style='padding-left: 16px; padding-right: 16px')
    table(style='width: 100%')
      tr
        td(style='text-align: left')
          img(src='https://csahome.com/wp-content/uploads/2020/06/mitra10.png', alt='Mitra 10 Logo', style='height: 48px')
        td(style='text-align: center')
          p(style='font-size: 1.25rem; font-weight: 600')
            | Instalasi &amp; Service Mitra 10
        td(style='text-align: right')
          .order-id
            p(style='\
            font-size: 1.125rem;\
            font-weight: 600;\
            margin: 0 !important;\
            ')
              | Refund ID: #{data.refund.id}
            p(style='\
            font-size: 0.875rem;\
            margin: 0 !important;\
            ')
              | Order ID: #{data.refund.orders.id}
  .divider(style='border-top: 1px solid #e5e7eb')
  .content(style='\
  padding-top: 16px;\
  padding-left: 24px;\
  padding-right: 24px;\
  ')
    p(style='color: #4a5568') #{data.message.welcome_header}, #{data.refund.orders.members.full_name}. #{data.message.greetings}
    p(style='\
    color: #4a5568;\
    font-weight: 600;\
    margin: 0 !important;\
    ')
      | Terima kasih telah melakukan order Layanan Jasa Instalasi &amp;
      | Service Mitra10
    p(style='\
    color: #4a5568;\
    font-weight: 600;\
    margin: 0 !important;\
    ')
      | Berikut detail pemesanan Anda:
  .order-info(style='padding: 20px')
    h1(style='\
    font-size: 1.25rem;\
    font-weight: 600;\
    margin-bottom: 16px;\
    ')
      | Informasi Order
    table(style='\
    width: 100%;\
    text-align: left;\
    border-collapse: collapse;\
    margin-bottom: 24px;\
    ')
      thead
        tr
          th(style='\
          min-width: 144px;\
          max-width: 144px;\
          border: 1px solid #e2e8f0;\
          padding: 8px;\
          ')
            | Kode Item
          th(style='\
          min-width: 176px;\
          max-width: 176px;\
          border: 1px solid #e2e8f0;\
          padding: 8px;\
          ')
            | Nama Item
          th(style='\
          min-width: 176px;\
          max-width: 176px;\
          border: 1px solid #e2e8f0;\
          padding: 8px;\
          ')
            | Nama Jasa Pemasangan
          th(style='border: 1px solid #e2e8f0; padding: 8px')
            | QTY Pemasangan
      tbody
        each item, index in data.reschedule.order.order_details
          tr
            td(style="min-width: 144px; max-width: 144px; border: 1px solid #e2e8f0; padding: 8px; word-break: break-word; font-size: 0.875rem;") #{item.item_code === 'null' ? '-' : (item.item_code || '-')}
            td(style="min-width: 176px; max-width: 176px; border: 1px solid #e2e8f0; padding: 8px; font-size: 0.875rem;") #{item.item_name === 'null' ? '-' : (item.item_name || '-')}
            td(style="min-width: 176px; max-width: 176px; border: 1px solid #e2e8f0; padding: 8px; font-size: 0.875rem;") #{item.service_name || '-'}
            td(style="border: 1px solid #e2e8f0; padding: 8px; font-size: 0.875rem;") #{item.quantity || 0}
        tr
           td(colspan="3", style="border: 1px solid #e2e8f0; padding: 8px; text-align: end; font-size: 0.875rem; font-weight: 600;") Biaya Survey
           td(style="border: 1px solid #e2e8f0; padding: 8px;") #{Number(data.reschedule.order.grand_total).toLocaleString('id')}
  .divider(style='border-top: 1px solid #e5e7eb')
  .customer-info(style='padding: 20px')
    h2(style='\
    font-size: 1.25rem;\
    font-weight: 600;\
    margin-bottom: 16px;\
    ')
      | Informasi Pelanggan
    p(style='color: #4a5568')
      strong Nama:
      |  #{data.reschedule.order.members.full_name}
    p(style='color: #4a5568')
      strong Email:
      |  #{data.reschedule.order.members.email}
    p(style='color: #4a5568')
      strong Nomor Telepon:
      |  #{data.reschedule.order.project_number}
    p(style='color: #4a5568')
      strong Alamat:
      |  #{data.reschedule.order.project_address}
  .divider(style='border-top: 1px solid #e5e7eb')
  .customer-info(style='padding: 20px')
    h2(style='\
    font-size: 1.25rem;\
    font-weight: 600;\
    margin-bottom: 16px;\
    ')
      | Detail Refund
    p(style='color: #4a5568')
      strong Tanggal Pengajuan Refund:
      |  #{data.refund.date_of_filling ? new Date(data.refund.date_of_filling).toLocaleDateString('en-US') : new Date(data.refund.created_at).toLocaleDateString('en-US')}
    p(style='color: #4a5568')
      strong Nomor Receipt Refund:
      | #{data.refund.approval_number ? data.refund.approval_number : data.refund.orders.receipt_number}
    p(style='color: #4a5568')
      strong Voucher Konsumen:
      |  #{data.refund.voucher}
    p(style='color: #4a5568')
      strong Alasan Refund:
      |  #{data.refund.reason}
  .divider(style='border-top: 1px solid #e5e7eb')
  .payment-instructions(style='padding: 20px')
    h2(style='\
    font-size: 1.25rem;\
    font-weight: 600;\
    margin-bottom: 16px;\
    ')
      | Intruksi Pembayaran
    p(style='margin-bottom: 8px; color: #4a5568; font-weight: 600')
      | 1. Silahkan melakukan pembayaran di account di bawah ini:
    ul(style='list-style-type: disc; margin-left: 5px')
      li(style='color: #4a5568') Bank: BCA
      li(style='color: #4a5568') Nomor Akun: 801-58-55840
      li(style='color: #4a5568')
        | Nama Akun: Catur Mitra Sejati Sentosa
    p(style='margin-bottom: 8px; color: #4a5568; font-weight: 600')
      | 2. Silahkan kirim bukti bayar anda melalui:
    ul(style='list-style-type: disc; margin-left: 5px')
      li(style='color: #4a5568') Email: payment@mitra10.com
      li(style='color: #4a5568') Whatsapp: +62 812-3456-7890
  .divider(style='border-top: 1px solid #e5e7eb')
  .information(style="padding: 20px;")
        h2(style="font-size: 1.25rem; font-weight: 600; margin-bottom: 16px;") Informasi
        each item, index in data.message.information_detail
          p(style="margin-bottom: 8px; color: #4a5568;") #{index + 1 + '. ' + item.information}

      .divider(style="border-top: 1px solid #e5e7eb;")

      .terms-conditions(style="padding: 20px;")
        h2(style="font-size: 1.25rem; font-weight: 600; margin-bottom: 16px;") Syarat dan Ketentuan
        each item, index in data.message.terms_detail
          p(style="margin-bottom: 8px; color: #4a5568;") #{index + 1 + '. ' + item.terms}
      .divider(style="border-top: 1px solid #e5e7eb;")
    
      .notes(style="padding: 20px;")
        p(style="color: #4a5568; font-weight: 600; margin-top: 10px; margin-bottom: 0px;") #{data.message.footer}
        p(style="color: #4a5568; margin: 0 !important;") Ini adalah email yang dikirimkan oleh sistem. Mohon untuk tidak membalas email ini.
      
      .footer(style="background-color: #edf2f7; padding: 20px; text-align: center;")
        p(style="font-size: 0.875rem; font-weight: 600; margin: 0 !important;") Jika Anda memiliki pertanyaan, jangan ragu untuk menghubungi kami di customer.relation@mitra10.com
        p(style="font-size: 0.875rem; font-weight: 600; margin: 0 !important;") &copy; 2024 Mitra10. All rights reserved.
      .footer-banner
        img(src=`${data.message && data.message.email_message_image && data.message.email_message_image.length > 0  ? `${data.apiUrl}/public/mails-image/${data.message.email_message_image.filter((x) => x.type === 2)[0].path}` : 'https://i.ibb.co.com/WfLzSHp/footer-email-instalasi-02.jpg'}` alt="Banner Image" style="width: 100%; height: auto;")