doctype html
html(lang="id")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Pendaftaran Vendor Dalam Proses Pitching - Mitra10
    body(style="margin:0;padding:0;background-color:#f0f2f5;font-family:Arial,Helvetica,sans-serif;")
        table(role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color:#f0f2f5;")
            tr
                td(style="padding:40px 10px;")
                    table(role="presentation" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width:600px;margin:0 auto;background-color:#ffffff;border-radius:8px;")
                        tr
                            td(style="background-color:#183383;padding:28px 35px;text-align:center;")
                                img(src="https://seeklogo.com/images/M/mitra-10-logo-5C2346D8FD-seeklogo.com.png" alt="Logo Mitra10" width="70" style="display:block;margin:0 auto 12px auto;border:0;")
                                h1(style="color:#ffffff;font-size:20px;font-weight:700;margin:0;") Instalasi &amp; Service Mitra10
                        tr
                            td(style="padding:32px 35px;")
                                h2(style="font-size:22px;color:#1a1a2e;margin:0 0 12px 0;") Halo, #{data.company_name}
                                p(style="font-size:14px;color:#495057;line-height:1.7;margin:0 0 16px 0;") Pendaftaran vendor Anda saat ini masuk ke tahap review dan proses pitching.
                                p(style="font-size:14px;color:#495057;line-height:1.7;margin:0;") Tim Mitra10 akan menghubungi kontak yang terdaftar apabila diperlukan diskusi lanjutan, klarifikasi data, atau kelengkapan informasi.
                        tr
                            td(style="background-color:#f8f9fa;padding:22px 35px;text-align:center;border-top:1px solid #e9ecef;")
                                p(style="font-size:11px;color:#6c757d;line-height:1.6;margin:0 0 6px 0;") Hormat kami,
                                    br
                                    strong Mitra10 Instalasi &amp; Service
                                p(style="font-size:11px;color:#6c757d;margin:0;") Email otomatis. Mohon jangan membalas.
