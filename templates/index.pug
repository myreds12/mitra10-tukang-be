  body.bg-gray-100.font-sans.leading-normal.tracking-normal
    .max-w-3xl.mx-auto.bg-white.shadow-md.rounded-lg.overflow-hidden
      .p-0
        img.w-full.h-auto(src='https://i.ibb.co.com/LhrxWt7/header-email-instalasi-01.jpg', alt='Banner Image')
      .p-4.flex.flex-col.md:flex-row.justify-between.items-center
        img.h-12(src='https://csahome.com/wp-content/uploads/2020/06/mitra10.png', alt='Mitra 10 Logo')
        p.ml-4.text-xl.font-semibold.text-center.
          
          Instalasi & Service Mitra 10
          
        .text-center.md:text-right
          p.text-lg.font-semibold Order ID : #{data.order.id}
          p.text-sm Tanggal Order : #{data.order.request_survey ? new Date(data.order.request_survey).toLocaleDateString('en-US') : '-'}
      .divide-y
        .pt-4.px-6
          p.text-gray-700 #{data.message.welcome_header} #{data.order.members.full_name} #{data.message.greetings}
          p.text-gray-700.font-semibold.
            
            Terima kasih telah melakukan order Layanan Jasa Instalasi & Service Mitra10
            
          p.text-gray-700.font-semibold Berikut detail pemesanan Anda :
        .p-5
          h1.text-xl.font-semibold.mb-4 Informasi Order
          table.w-full.text-left.table-auto.border-collapse.mb-6
            thead
              tr
                th.min-w-36.max-w-36.border.px-4.py-2 Kode Item
                th.min-w-44.max-w-44.border.px-4.py-2 Nama Item
                th.min-w-44.max-w-44border.px-4.py-2 Nama Jasa Pemasangan
                th.border.px-4.py-2 QTY Pemasangan
            tbody
              each item, index in data.order.order_details
                tr
                  td.min-w-36.max-w-36.border.px-4.py-2.break-words.break-all.text-sm= item.item_code === 'null' ? '-' : (item.item_code || '-')
                  td.min-w-44.max-w-44.border.px-4.py-2.text-sm= item.item_name === 'null' ? '-' : (item.item_name || '-')
                  td.min-w-44.max-w-44border.px-4.py-2.text-sm= item.service_name
                  td.border.px-4.py-2.text-sm= item.quantity || 0
              tr
                td.border.px-4.py-2.text-end.text-sm.font-semibold(colspan='3') Biaya Survey
                - var formattedSurveyPrice = 'Rp. ' + data.grand_total.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.')
                td.border.px-4.py-2 #{formattedSurveyPrice}
      .divide-y
        .p-5
          h2.text-xl.font-semibold.mb-4 Informasi Pelanggan
          .mb-5
            p.text-gray-700
              strong Nama:
              |  #{data.order.members.full_name}

            p.text-gray-700
              strong Email:
              |  #{data.order.members.email}

            p.text-gray-700
              strong Nomor Telepon:
              |  #{data.order.project_number}

            p.text-gray-700
              strong Alamat:
              |  #{data.order.project_address}

        .p-5
          h2.text-xl.font-semibold.mb-4 Intruksi Pembayaran
          .payment-information.mb-3
            p.mb-2.text-gray-700.font-semibold 1. Silahkan melakukan pembayaran di account di bawah ini:
            ul.list-disc
              li.text-gray-700 Bank: #{data.order.store.bank_name}
              li.text-gray-700 Nomor Akun: #{data.order.store.bank_number}
              li.text-gray-700 Nama Akun: #{data.order.store.bank_account}
          .payment-evidence
            p.mb-2.text-gray-700.font-semibold 2. Silahkan kirim bukti bayar anda melalui:
            ul.list-disc
              li.text-gray-700 Email: #{data.order.store.email ? data.order.store.email : 'Email belum tersedia'}
              li.text-gray-700 Whatsapp: #{data.order.store.phone_number_1 ? data.order.store.phone_number_1 : data.order.store.phone_number_2}               
        .p-5
          h2.text-xl.font-semibold.mb-4 Informasi
          each item, index in data.message.information_detail
            p.mb-2.text-gray-700= index + 1 + '. ' + item.information
        .p-5
          h2.text-xl.font-semibold.mb-4 Syarat dan Ketentuan
          each item, index in data.message.terms_detail
            p.mb-2.text-gray-700= index + 1 + '. ' + item.terms
        .py-3.px-5
          p.mt-4.text-gray-700.font-semibold #{data.message.footer}
          p.mt-1.text-gray-700 Ini adalah email yang dikirimkan oleh sistem. Mohon untuk tidak membalas email ini.
      .bg-gray-200.p-5.text-center
        p.text-sm.font-semibold Jika Anda memiliki pertanyaan, jangan ragu untuk menghubungi kami di customer.relation@mitra10.com
        p.text-sm.font-semibold © 2024 Mitra10. All rights reserved.
      //  After Footer 
      .p-0
        img.w-full.h-auto(src='https://i.ibb.co.com/WfLzSHp/footer-email-instalasi-02.jpg', alt='Banner Image')