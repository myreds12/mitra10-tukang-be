doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Template Email
    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    )
    style.
      * {
        margin: 0;
        padding: 0;
      }

      h1 {
        padding: 4px;
        font-size: 20px;
      }

      h2 {
        padding: 4px;
        font-size: 18px;
      }

      h3 {
        padding: 4px;
        font-size: 16px;
      }

      .fw-bold {
        font-weight: bold;
      }

      .fw-normal {
        font-weight: normal;
      }

      #preview-email {
        display: block;
        margin: auto;
        font-family: Arial, Helvetica, sans-serif;
      }

      #preview-email .card {
        margin: 20px;
        padding: 10px;
        box-shadow: 0px 0px 4px 0px rgba(0, 0, 0, 0.25);
      }

      #preview-email .card-header {
        border-radius: 5px 5px 0px 0px;
        width: 100%;
      }

      #preview-email .card-body {
        margin: 30px;
      }

      #preview-email img.logo-mitra {
        width: 100px;
        height: fit-content;
      }

      #preview-email .header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
      }

      #preview-email .header .logo {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      #preview-email .card-footer {
        border-radius: 0px 0px 5px 5px;
        width: 100%;
      }

      #preview-email .button-csi {
        margin: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
      }

      #preview-email img.link-csi {
        width: fit-content;
        height: 90px;
      }

      #preview-email table.table {
        width: 100%;
        table-layout: fixed; /* Memperbesar kolom */
        border: 1px solid black !important;
      }

      #preview-email table.table td {
        font-size: 14px; /* Memperkecil ukuran teks */
        padding: 10px; /* Menambahkan padding pada kolom */
        border: 1px solid black !important;
      }

      #preview-email table.table th {
        font-size: 14px; /* Memperkecil ukuran teks */
        padding: 10px; /* Menambahkan padding pada kolom */
        border: 1px solid black !important;
      }

      #preview-email table.table tr {
        font-size: 14px; /* Memperkecil ukuran teks */
        padding: 10px; /* Menambahkan padding pada kolom */
        border: 1px solid black !important;
      }

      /* Styling untuk checkbox dan label */
      .checkbox-container {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .checkbox-container input[type="checkbox"] {
        width: 20px;
        height: 20px;
        cursor: default;
        border: 2px solid black; /* Mempertebal border checkbox */
        accent-color: black; /* Mengatur warna isi checkbox */
      }

      .checkbox-container label {
        margin: 0;
        font-size: 14px;
      }

      @media screen and (max-width: 576px) {
        #preview-email .header .logo {
          margin-bottom: 20px;
        }

        #preview-email .card-body .header {
          display: flex;
          flex-direction: column;
          align-items: start;
          margin-bottom: 20px;
        }
      }

  body
    section#preview-email
      .card
        .card-body
          .header
            .logo
              img.logo-mitra(src="https://csahome.com/wp-content/uploads/2020/06/mitra10.png" alt="Mitra10")
              h1 Instalasi & Service Mitra 10
          .content
            h3.fw-normal Laporan Follow Up Order CSI
            .table-responsive
              table.table.table-bordered
                thead.table-primary
                  tr
                    th Order ID
                    th Tanggal Order
                    th Nama Toko
                    th Nama Customer
                    th Nama Pemasangan
                    th Status Order
                    th CSI Survei
                    th CSI Pengerjaan
                    th Catatan
                tbody
                  each workOrder in data.orders
                    tr
                      td #{workOrder.id}
                      td #{new Date(workOrder.created_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                      td #{workOrder.store.store_name}
                      td #{workOrder.members.full_name}
                      td #{workOrder.m_order_details.map((item) => item.item_name).join(', ')}
                      td #{workOrder.status.description}
                      td
                        .checkbox-container
                          - if (workOrder.order_follow_up[0])
                            input(type="checkbox", checked=workOrder.order_follow_up[0].csi_survey, disabled=true)
                          - else
                            input(type="checkbox", disabled=true)
                      td
                        .checkbox-container
                          - if (workOrder.order_follow_up[0])
                            input(type="checkbox", checked=workOrder.order_follow_up[0].csi_work, disabled=true)
                          - else
                            input(type="checkbox", disabled=true)
                      td
                        - if (workOrder.order_follow_up[0])
                          | #{workOrder.order_follow_up[0].description}
                        - else
                          | -

    script(
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
      integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
      crossorigin="anonymous"
    )
    script(
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.min.js"
      integrity="sha384-0pUGZvbkm6XF6gxjEnlmuGrJXVbNuzT9qBBavbLwCsOGabYfZo0T0to5eqruptLy"
      crossorigin="anonymous"
    )
