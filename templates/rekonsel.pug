doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Template PDF Invoice
  style.
    * {
    margin: 0;
    padding: 0;
    font-family: Arial, Helvetica, sans-serif;
    }
    /* Container */
    #invoice {
    max-width: 1140px;
    margin: 50px auto;
    padding: 20px;
    }
    .row {
    display: flex;
    flex-wrap: wrap;
    margin-right: -15px;
    margin-left: -15px;
    }
    .mb-3 {
    margin-bottom: 20px;
    }
    .fw-semibold {
    font-weight: 600;
    }
    .col-12,
    .col-xxl-8,
    .col-xl-8,
    .col-lg-8,
    .col-md-8,
    .col-md-6,
    .col-xxl-6,
    .col-xl-6,
    .col-lg-6,
    .col-md-6,
    .col-sm-12,
    .col-xs-12,
    .col-xxl-4,
    .col-xl-4,
    .col-md-4,
    .col-sm-12 {
    padding-right: 15px;
    padding-left: 15px;
    box-sizing: border-box;
    }
    .col-12 {
    flex: 0 0 100%;
    max-width: 100%;
    }
    .col-xxl-8,
    .col-xl-8,
    .col-lg-8,
    .col-md-8 {
    flex: 0 0 66.67%;
    max-width: 66.67%;
    }
    .col-xxl-6,
    .col-xl-6,
    .col-lg-6,
    .col-md-6 {
    flex: 0 0 50%;
    max-width: 50%;
    }
    .col-xxl-4,
    .col-xl-4,
    .col-md-4 {
    flex: 0 0 33.33%;
    max-width: 33.33%;
    }
    .col-sm-12,
    .col-xs-12 {
    flex: 0 0 100%;
    max-width: 100%;
    }
    /* Header */
    .vendor-information {
    padding-right: 0px;
    }
    .invoice-information {
    padding-left: 0px;
    }
    .vendor-information h1 {
    color: #007eb4;
    font-size: 30px;
    padding-bottom: 10px;
    }
    .invoice-information h1 {
    color: #484747;
    font-size: 30px;
    padding-bottom: 10px;
    }
    /* Content */
    .table {
    width: 50%;
    border-collapse: collapse;
    margin-bottom: 1rem;
    background-color: transparent;
    }
    .table th,
    .table td {
    padding: 0.50rem;
    vertical-align: top;
    border: 1px solid #dee2e6;
    }
    .table th {
    font-size: 10px;
    font-weight: 600;
    color: white;
    background-color: #555555;
    }
    .table td {
    font-size: 6px;
    }
    .text-end {
    text-align: right;
    }
    .text-center {
    text-align: center;
    }
    /* Footer */
    .payment-information .payment-method,
    .payment-information .payment-evidence {
    margin-bottom: 10px;
    }
    .signature-line {
    width: 200px;
    margin: 150px 0 10px 0;
    border-bottom: 1px solid #000;
    }
    @media screen and (max-width: 991px) {
    .vendor-information {
    padding: 0;
    margin-bottom: 20px;
    }
    .receiver-information {
    padding: 0;
    margin-bottom: 20px;
    }
    .invoice-information {
    padding: 0;
    margin-bottom: 20px;
    }
    .notes {
    padding: 0;
    margin-bottom: 20px;
    }
    }
    @media screen and (max-width: 768px) {
    .signature {
    justify-content: start !important;
    }
    .signature-wrapper {
    flex-direction: column;
    }
    }
    @media screen and (max-width: 576px) {
    .approver-wrapper {
    flex-direction: column;
    }
    }
    @media print {
    .table-responsive {
    overflow: visible !important;
    max-height: none !important;
    }
    .invoice-wrapper {
    margin-top: 3rem;
    margin-bottom: 3rem;
    min-height: 50vh;
    page-break-after: always;
    }
    .footer {
    margin-top: 3rem;
    margin-bottom: 3rem;
    page-break-before: always;
    }
    }
section#invoice
  - const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
  - const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
  - const today = new Date();
  - const dayName = days[today.getDay()];
  - const day = today.getDate();
  - const month = months[today.getMonth()];
  - const year = today.getFullYear();
  - const currentMonth = today.getMonth();
  - const previousMonth = currentMonth === 0 ? 11 : currentMonth - 1;
  - const currentYear = today.getFullYear();
  - const previousYear = currentMonth === 0 ? currentYear - 1 : currentYear;
  .invoice-wrapper
    .header.mb-3
      .row.d-flex.flex-column.flex-md-row
        .col-md-6.order-2.order-md-1
          .vendor-information
            h1 #{data.invoice.vendor.company_name}
            div
              | #{data.invoice.vendor.address}
        .col-md-6.order-1.order-md-2
          .invoice-information
            h1 INVOICE
            div
              | Invoice ID: 
              span #{data.invoice.invoice_id}
            div
              | Tanggal dibuat:
              - var formateCreatedAt = new Date(data.invoice.created_at).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
              span #{formatedCreatedAt}
            div
              | Periode:
              span #{months[previousMonth]} - #{months[currentMonth]} #{previousMonth > currentMonth ? previousYear : currentYear}
            div
              | Tanggal diberikan kepada Finance:
              span
                | #{data.invoice.invoice_to_finance_date}
      .row
        .col-md-6
          .receiver-information
            div Ditunjukkan kepada :
            div
              strong PT Catur Mitra Sejati Sentosa
            div
              | Jl. Gading Serpong Boulevard Blok mitra 10,
              | Curug Sangereng, Kec. Klp. Dua, Kabupaten
              | Tangerang, Banten 15820
            div Telp : 0878-8482-1089
        .col-md-6
    .content
      table.table.table-bordered
        thead
          tr
            th No
            th Order ID
            th.text-center Nama Customer
            th.text-center Nama Pemasangan
            th.text-center Tanggal Survey/Pengerjaan
            th.text-center Total Harga
            th.text-center Transaksi Customer
            th.text-center Harga Jasa
            th.text-center Margin PPN
            th.text-center Selisih Non PPN
            th.text-center Margin
            th.text-center No Receipt
        tbody
        -let totals = { customer_transaction: 0, invoice_price: 0, instalation_price: 0, margin_ppn: 0, margin_non_ppn: 0, margin: 0 };
        each item, index in data.invoice.invoice_details
          tr(key=`${index} - quotation details`)  
            -const customer_transaction = item.order.payment_type !== 'survey' ? item.order.grand_total : (item.type === 2 && item.order.payment_type === 'survey' && item.order.quotation[0]) ? item.order.quotation[0].quotation_grand_total : item.order.grand_total;
            -const invoice_price = item.total;
            -const instalation_price = Math.floor(+customer_transaction / 1.11);
            -const margin_ppn = instalation_price - invoice_price;
            -const price_difference = +customer_transaction - invoice_price;
            -const receipt_number = item.order.quotation.length ? item.order.quotation[0].receipt_quotation : item.order.receipt_number;
            td #{index + 1} 
            td #{item.order_id}
            td.text-center #{item.order.members.full_name}
            td #{item.order.m_order_details.map((x) => x.item_name || '-').join(', ')}
            - const orderCreatedAt = new Date(item.order.request_work ? item.order.request_work : item.order.request_survey || '-').toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
            td.text-center #{orderCreatedAt}
            td.text-center #{invoice_price}
            td.text-center #{Number(customer_transaction)}
            td.text-center #{instalation_price}
            td.text-center #{`${isNaN(margin_ppn / instalation_price) ? 0 : Math.ceil((margin_ppn / instalation_price) * 100)}%`}
            td.text-center #{Math.ceil(price_difference / 1.11)}
            td.text-center #{`${Math.ceil(((Math.ceil(price_difference / 1.11)) / +customer_transaction) * 100)}%`}
            td.text-center #{receipt_number}

            -totals.customer_transaction += +customer_transaction;
            -totals.invoice_price += invoice_price;
            -totals.instalation_price += instalation_price;
            -totals.margin_ppn += isNaN(margin_ppn) ? 0 : Math.ceil(margin_ppn);
            -totals.margin_non_ppn += Math.ceil(price_difference / 1.11);
            -totals.margin += Math.ceil((price_difference / +customer_transaction) * 100);
        tr
          td(colspan="5").fw-bold Total
          td.fw-bold Rp. #{totals.invoice_price.toLocaleString('id')}
          td.fw-bold Rp. #{totals.customer_transaction.toLocaleString('id')}
          td.fw-bold Rp. #{totals.instalation_price.toLocaleString('id')}
          td.fw-bold #{`${totals.margin_ppn}%`}
          td.fw-bold Rp. #{totals.margin_non_ppn.toLocaleString('id')}
          td.fw-bold #{`${totals.margin}%`}
          td.fw-bold
          td.fw-bold
    .footer
      .payment-information
        .payment-method
          .fw-semibold
            | Silahkan melakukan pembayaran di account di
            | bawah ini :
          div Nama Akun : #{data.invoice.vendor.company_name}
          div Nomor Akun : #{data.invoice.vendor.account_number}
        .payment-evidence
          .fw-semibold
            | Silahkan kirim bukti bayar anda melalui :
          div WA : #{data.invoice.vendor.phone_number}
          div Email : #{data.invoice.vendor.email_address}
      .signature.row
        .col-8.col-xxl-8.col-xl-8.col-md-8
        .col-4.col-xxl-4.col-xl-4.col-md-4
          .fs-6.fw-semibold Tanda Tangan :
          .fs-6.fw-semibold
            | #{dayName}, #{day} #{month} #{year}
          .signature-line
          .fs-6 #{data.invoice.vendor.company_name}
